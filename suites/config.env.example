# Traffic Generator Configuration
# Copy to /opt/traffic-generator/config.env on the VM

# Required: target FQDN (F5 XC load balancer domain)
TARGET_FQDN=demo.example.com

# Protocol: http or https (default: http for direct origin, https for F5 XC LB)
TARGET_PROTOCOL=http

# Optional: direct origin IP for baseline testing (bypasses F5 XC)
TARGET_ORIGIN_IP=

# crAPI port (default 8888 — crAPI microservices run on separate port)
CRAPI_PORT=8888
